<!-- Created with Jaspersoft Studio version 6.18.1.final using JasperReports Library version 6.18.1-9d75d1969e774d4f179fb3be8401e98a0e6d1611  -->
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Representacion_Grafica" pageWidth="612" pageHeight="792" columnWidth="612" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="3f9782d9-0514-4528-84c0-0bc0a3a6d598">
	<property name="ireport.zoom" value="2.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="1106"/>
	<import value="java.awt.Image"/>
	<parameter name="representacion_grafica_id" class="java.lang.String"/>
	<parameter name="hints" class="java.util.Map"/>
	<queryString>
		<![CDATA[SELECT 
t.folio_control,
t.libro,
t.foja,
DATE_FORMAT(e.fecha_expedicion, "%Y-%m-%d") AS fecha_expedicion,
p.curp,
p.nombre,
p.primer_apellido,
p.segundo_apellido,
CONCAT(p.nombre, " ", p.primer_apellido, " ", p.segundo_apellido) AS nombre_completo,
i.nombre_institucion,
i.cve_institucion,
c.nombre_carrera,
c.cve_carrera,
c.autorizacion_reconocimiento,
IF(LENGTH(TRIM(c.numero_rvoe)) > 0, c.numero_rvoe, "N/A") AS numero_rvoe,
DATE_FORMAT(c.fecha_inicio, "%Y-%m-%d") AS fecha_inicio,
DATE_FORMAT(c.fecha_terminacion, "%Y-%m-%d") AS fecha_terminacion,
IF(e.id_modalidad_titulacion = 1, "exención de ", "") AS excencion,
IF(e.id_modalidad_titulacion = 1, DATE_FORMAT(e.fecha_examen_profesional, "%Y-%m-%d"), DATE_FORMAT(e.fecha_exencion_examen_profesional, "%Y-%m-%d")) AS fecha_examen,
e.entidad_federativa,
r.cadena_original,
r.sello,
r.certificado_responsable,
r.no_certificado_responsable,
DATE_FORMAT(r.fecha_registro, "%Y-%m-%dT%H:%i:%s") as fecha_certificacion,
COUNT(*) AS numero_firmas,
rg.codigo AS codigo_generacion,
DATE_FORMAT(rg.fecha_registro, "%Y-%m-%d %T") AS fecha_generacion,
GROUP_CONCAT(
CONCAT("\t- ", REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(r.cargo, "Á", "A"), "É", "E"), "Í", "I"), "Ó", "O"), "Ñ", "N"), "Ú", "U"), ": ", UPPER(r.abr_titulo), " ", UPPER(r.nombre)," ",UPPER(r.primer_apellido)," ", UPPER(r.segundo_apellido)
) SEPARATOR '\n') AS firmantes,
CONCAT(UPPER(r.abr_titulo), " ", UPPER(r.nombre)," ",UPPER(r.primer_apellido)," ", UPPER(r.segundo_apellido), ", ", UPPER(pu.cargo)) AS firmante
FROM repg_representacion_grafica rg 
JOIN xml_titulo_electronico t ON rg.titulo_electronico_id = t.id AND rg.id = $P{representacion_grafica_id}
LEFT JOIN xml_institucion i ON i.id = t.institucion_id
LEFT JOIN xml_carrera c ON c.id = t.carrera_id
LEFT JOIN xml_profesionista p on p.id = t.profesionista_id
LEFT JOIN xml_expedicion e ON e.id = t.expedicion_id
LEFT JOIN xml_antecedente a ON a.id = t.antecedente_id
LEFT JOIN xml_firma_responsables frs ON frs.id = t.firma_responsables_id 
LEFT JOIN xml_firma_responsable r ON frs.id = r.firma_responsables_id
LEFT JOIN (
SELECT * FROM seg_perfil pu GROUP BY pu.curp
) pu ON pu.curp = r.curp
GROUP BY t.id]]>
	</queryString>
