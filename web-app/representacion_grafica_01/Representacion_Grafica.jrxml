				<reportElement mode="Transparent" x="48" y="634" width="514" height="17" backcolor="#F7F7F7" uuid="3970bdd7-7c76-4e1e-b456-aa349567f9db"/>
				<textElement textAlignment="Left" verticalAlignment="Top">
					<font fontName="Soberana Sans" size="7"/>
				</textElement>
				<textFieldExpression><![CDATA["Fecha y hora de certificación: " + $F{fecha_certificacion}]]></textFieldExpression>
